// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  CHECKIN_STAFF
  ADMIN
}

enum WorkshopStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CANCELLED
  EXPIRED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String   @map("full_name")
  mssv      String?  @map("mssv")
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  registrations WorkshopRegistration[]

  @@map("users")
}

model Workshop {
  id             String         @id @default(uuid())
  title          String
  description    String?
  category       String?
  speakerInfo    String?        @map("speaker_info")
  location       String?
  room           String
  startTime      DateTime       @map("start_time")
  endTime        DateTime?      @map("end_time")
  capacity       Int
  availableSeats Int            @default(0) @map("available_seats")
  price          Decimal        @default(0)
  aiSummary      String?        @map("ai_summary")
  status         WorkshopStatus @default(DRAFT)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")


  registrations WorkshopRegistration[]
  checkins      WorkshopCheckIn[]

  @@map("workshops")
}

model WorkshopRegistration {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  workshopId String             @map("workshop_id")
  status     RegistrationStatus @default(PENDING)
  qrToken    String?            @unique @map("qr_token")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id])
  workshop Workshop         @relation(fields: [workshopId], references: [id])
  checkin  WorkshopCheckIn?
  payments Payment[]

  @@unique([userId, workshopId])
  @@map("workshop_registrations")
}

model Payment {
  id             String   @id @default(uuid())
  registrationId String   @map("registration_id")
  amount         Decimal
  status         String
  transactionId  String?  @map("transaction_id")
  createdAt      DateTime @default(now()) @map("created_at")

  registration WorkshopRegistration @relation(fields: [registrationId], references: [id])

  @@map("payments")
}

model WorkshopCheckIn {
  id             String   @id @default(uuid())
  registrationId String   @unique @map("registration_id")
  workshopId     String   @map("workshop_id")
  scannedAt      DateTime @default(now()) @map("scanned_at")

  registration WorkshopRegistration @relation(fields: [registrationId], references: [id])
  workshop     Workshop             @relation(fields: [workshopId], references: [id])

  @@map("workshop_checkins")
}

